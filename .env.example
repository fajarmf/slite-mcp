# =============================================================================
# Slite MCP Server Configuration
# =============================================================================

# Required: Your Slite API key
# Get your API key from: https://slite.com/api (Settings > Integrations > API)
SLITE_API_KEY=your_slite_api_key_here

# =============================================================================
# Test Configuration (Optional)
# =============================================================================
# Run `npm run test:setup` to create test documents automatically.
# The script creates 55 child notes (>50 needed for cursor pagination testing).

# TEST_NOTE_ID: Parent note containing test children
# - Child 1: "Test Data for MCP Server" with searchable keyword MCP_UNIQUE_TEST_KEYWORD_123
# - Children 2-55: Pagination test notes
#
# Tests automatically fetch children from this parent note.
# TEST_NOTE_ID=your_parent_note_id_here

# =============================================================================
# Optional: Multiple API Keys
# =============================================================================
# For testing multiple Slite workspaces/accounts

# SLITE_API_KEY_2=your_second_api_key_here
