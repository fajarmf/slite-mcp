{
  "name": "slite-mcp",
  "version": "1.0.0",
  "description": "Model Context Protocol server for Slite integration - search and retrieve notes from your Slite workspace",
  "main": "build/index.js",
  "bin": {
    "slite-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "npx tsc",
    "start": "node build/index.js",
    "test": "node tests/test-slite-api.js",
    "test:api": "node tests/test-slite-api.js",
    "test:note": "node tests/test-specific-note.js",
    "test:errors": "node tests/test-error-handling.js",
    "test:mcp": "node tests/test-mcp-integration.js",
    "test:edge": "node tests/test-edge-cases.js",
    "test:all": "npm run test:api && npm run test:errors && npm run test:edge && npm run test:mcp",
    "test:setup": "node tests/setup-test-data.js"
  },
  "keywords": [
    "mcp",
    "slite",
    "model-context-protocol",
    "ai",
    "notes",
    "knowledge-base"
  ],
  "author": "Fajar Firdaus",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fajarmf/slite-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "dotenv": "^17.2.3",
    "typescript": "^5.0.0"
  }
}
